datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

// 1. Organization (Tenant)
model Organization {
  id                  String               @id @default(uuid())
  name                String               @unique // e.g., "City of Newark"
  slug                String               @unique // e.g., "newark"
  organizationType    String               @default("MUNICIPALITY")
  status              String               @default("ACTIVE")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @default(now()) @updatedAt
  enabledModules      String               @default("all")
  
  // Relations
  memberships         Membership[]
  invitations         Invitation[]
  profiles            Profile[]
  customRoles         CustomRole[]
  properties          Property[]
  businesses          Business[]
  projects            Project[]
  permits             Permit[]
  inspections         Inspection[]
  trackerItems        TrackerItem[]
  openRecordsRequests OpenRecordsRequest[]
  employees           Employee[]
  auditLogs           AuditLog[]
  municipalOffices    MunicipalOffice[]
  verificationClaims  VerificationClaim[]
  appointments        Appointment[]
  caseComments        CaseComment[]
}

// 2. Custom Role System (Isolated Per Org)
model CustomRole {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String        // e.g., "Water Dept Inspector", "Code Officer"
  createdAt      DateTime      @default(now())

  // Relations
  permissions    Permission[]
  profiles       Profile[]
  memberships    Membership[]
  invitations    Invitation[]

  @@unique([organizationId, name]) // Names are unique within a single organization
}

// 3. Granular Module Permissions
model Permission {
  id             String        @id @default(uuid())
  roleId         String
  role           CustomRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module         String        // "command-center" | "tracker" | "gis" | "permits" | "code-enforcement" | "legislative" | "open-records" | "staff-audit"
  canView        Boolean       @default(false)
  canEdit        Boolean       @default(false)
  createdAt      DateTime      @default(now())

  @@unique([roleId, module])    // Unique permission card per module per role
}

// 4. User Profile (linked to Supabase auth.users.id)
model Profile {
  id                 String               @id // Maps to Supabase auth.users.id
  email              String               @unique
  normalizedEmail    String               @default("")
  firstName          String?
  lastName           String?
  displayName        String?
  badgeId            String?              @unique
  identityProvider   String               @default("SupabaseAuth")
  externalIdentityId String?
  status             String               @default("ACTIVE")
  lastLoginAt        DateTime?
  
  // Platform Permissions
  isGlobalAdmin      Boolean              @default(false)
  isOrgAdmin         Boolean              @default(false)
  
  // Primary Organization Context
  organizationId     String?              
  organization       Organization?        @relation(fields: [organizationId], references: [id])
  roleId             String?              
  role               CustomRole?          @relation(fields: [roleId], references: [id])
  districtOfficeId   String?
  districtOffice     MunicipalOffice?     @relation(fields: [districtOfficeId], references: [id])
  
  // Relations
  memberships        Membership[]
  sentInvitations    Invitation[]         @relation("InvitedBy")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @default(now()) @updatedAt
  employee           Employee?
  verificationClaims VerificationClaim[]
}

// 4.5. Multi-Tenant Membership (Connects User to multiple Orgs)
model Membership {
  id             String        @id @default(uuid())
  userId         String        
  user           Profile       @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  roleId         String?
  role           CustomRole?   @relation(fields: [roleId], references: [id])
  departmentId   String?       
  divisionId     String?       
  jobTitle       String?       
  status         String        @default("ACTIVE") // "ACTIVE" | "SUSPENDED" | "INACTIVE"
  isPrimary      Boolean       @default(false)
  joinedAt       DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt

  @@unique([userId, organizationId]) // Composite unique constraint for multi-tenancy!
}

// 5. Enterprise Multi-Tenant Invitation Model
model Invitation {
  id                 String        @id @default(uuid())
  organizationId     String
  organization       Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email              String        
  normalizedEmail    String        
  roleId             String?
  role               CustomRole?   @relation(fields: [roleId], references: [id])
  departmentId       String?
  divisionId         String?
  jobTitle           String?
  invitedByUserId    String
  invitedByUser      Profile       @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  tokenHash          String        @unique @default(dbgenerated("gen_random_uuid()"))
  status             String        @default("PENDING") // "PENDING" | "ACCEPTED" | "EXPIRED" | "REVOKED" | "CANCELLED"
  sentAt             DateTime      @default(now())
  expiresAt          DateTime
  acceptedAt         DateTime?
  revokedAt          DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @default(now()) @updatedAt

  @@unique([organizationId, normalizedEmail]) // Composite constraint per Tenant & Email!
}

// Operational Tables
model Property {
  id             String         @id @default(uuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  address        String         @unique
  zipCode        String
  ownerName      String
  assessedValue  Float
  taxStatus      String         // "Paid" | "Delinquent"
  zoningDistrict String
  notes          String?
  permits        Permit[]
  inspections    Inspection[]
  trackerItems   TrackerItem[]
}

model Business {
  id               String         @id @default(uuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id])
  name             String         @unique
  sector           String
  complianceRating String         // "Grade A"
  projects         Project[]
}

model Project {
  id             String         @id @default(uuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  name           String         @unique
  status         String         // "Active" | "Completed"
  businessId     String
  business       Business       @relation(fields: [businessId], references: [id])
  permits        Permit[]
}

model Permit {
  id             String         @id @default(uuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  permitNumber   String         @unique
  type           String         // "Building" | "Zoning"
  status         String         // "Issued" | "Approved"
  estimatedCost  Float
  propertyId     String
  property       Property       @relation(fields: [propertyId], references: [id])
  projectId      String?
  project        Project?       @relation(fields: [projectId], references: [id])
  inspections    Inspection[]
}

model Inspection {
  id             String         @id @default(uuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  type           String         // "Structural" | "Safety"
  scheduledDate  DateTime
  status         String         // "Passed" | "Failed"
  inspectorName  String
  notes          String
  propertyId     String
  property       Property       @relation(fields: [propertyId], references: [id])
  permitId       String?
  permit         Permit?        @relation(fields: [permitId], references: [id])
}

model TrackerItem {
  id             String         @id @default(uuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  module         String         // "311" | "Permits"
  title          String
  status         String         // "Open" | "Resolved"
  priority       String         // "High" | "Medium"
  assignedTo     String
  slaDays        Int
  slaProgress    Int
  reportedDate   DateTime       @default(now())
  propertyId     String
  property       Property       @relation(fields: [propertyId], references: [id])
  
  // Office associations: origin branch & target processing branch
  originOfficeId String?
  originOffice   MunicipalOffice? @relation("OriginOffice", fields: [originOfficeId], references: [id])
  targetOfficeId String?
  targetOffice   MunicipalOffice? @relation("TargetOffice", fields: [targetOfficeId], references: [id])
}

// 6. Open Records (FOIA-style Requests)
model OpenRecordsRequest {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  requesterName  String
  requesterEmail String
  description    String
  dateRange      String?
  status         String       @default("Received") // "Received" | "Under Review" | "Fulfilled" | "Denied"
  assignedTo     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// 7. Employee (Staff Directory)
model Employee {
  id             String          @id @default(uuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  profileId      String?         @unique
  profile        Profile?        @relation(fields: [profileId], references: [id])
  
  firstName      String
  lastName       String
  email          String
  department     String          // "Code Enforcement" | "Public Works" | "City Clerk" etc.
  hireDate       DateTime
  
  // Branch Office Affiliation (Staff/Aides)
  officeId       String?
  office         MunicipalOffice? @relation(fields: [officeId], references: [id])
  
  // Relations
  certifications Certification[]
  timesheets     Timesheet[]
}

// 8. Staff Certifications
model Certification {
  id             String       @id @default(uuid())
  employeeId     String
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name           String       // e.g. "Structural Building Inspector Level II"
  credentialId   String
  issuedDate     DateTime
  expiresAt      DateTime
  alertSent      Boolean      @default(false)
}

// 9. Simple Timesheet Tracker
model Timesheet {
  id             String       @id @default(uuid())
  employeeId     String
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date           DateTime
  hoursWorked    Float
  notes          String?
}

// 10. System-wide Audit Ledger
model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?      
  userEmail      String?
  action         String       // "CREATE" | "UPDATE" | "DELETE" | "APPROVE"
  tableName      String       
  recordId       String       
  oldValues      Json?
  newValues      Json?
  createdAt      DateTime     @default(now())
}

// 11. Municipal Branch / Office Model
model MunicipalOffice {
  id             String            @id @default(uuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name           String            // e.g. "Mayor's Office", "Ward 1 Council Office"
  branch         String            // "EXECUTIVE" | "LEGISLATIVE" | "JUDICIAL"
  districtNumber String?           // e.g. "Ward 1" if council district-based
  
  // Relations
  employees      Employee[]
  profiles       Profile[]
  appointments   Appointment[]
  originTrackerItems TrackerItem[] @relation("OriginOffice")
  targetTrackerItems TrackerItem[] @relation("TargetOffice")
  caseComments   CaseComment[]
}

// 12. Property/Project Verification Claims (Self-Service)
model VerificationClaim {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  profileId      String
  profile        Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  type           String       // "RESIDENT_PROPERTY" | "CONTRACTOR_PROJECT" | "CONTRACTOR_PROPERTY"
  targetId       String       // UUID of the Property or Project being claimed
  targetAddress  String       // Human readable location address
  notes          String?      // Optional upload details / validation notes
  status         String       @default("PENDING") // "PENDING" | "VERIFIED" | "REJECTED"
  
  reviewedById   String?      
  reviewedAt     DateTime?
  createdAt      DateTime     @default(now())
}

// 13. Appointment Schedule
model Appointment {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  requesterName  String
  requesterEmail String
  department     String       // "Mayor's Office" | "Zoning Board" etc.
  scheduledAt    DateTime
  purpose        String
  
  type           String       // "APPOINTMENT" | "WALK_IN"
  status         String       @default("Scheduled") // "Scheduled" | "Completed" | "Cancelled"
  
  // Office mapping link
  officeId       String?
  office         MunicipalOffice? @relation(fields: [officeId], references: [id])
  
  // Optional link to operations tracker case if escalated
  trackerItemId  String?
  createdAt      DateTime     @default(now())
}

// 14. Unified In-Context Case Message / Comment Model
model CaseComment {
  id             String           @id @default(uuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  authorId       String           // Profile ID
  authorName     String           // e.g. "Elena Rostova"
  authorEmail    String
  
  authorOfficeId String?
  authorOffice   MunicipalOffice? @relation(fields: [authorOfficeId], references: [id])
  
  recordType     String           // "Property" | "Permit" | "Inspection" | "TrackerItem" | "OpenRecordsRequest"
  recordId       String           // Target row UUID
  message        String
  createdAt      DateTime         @default(now())
}

// 15. Marketing Lead / Demo Request Table
model DemoRequest {
  id             String       @id @default(uuid())
  name           String
  email          String
  municipality   String
  notes          String?
  createdAt      DateTime     @default(now())
}
