datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. Organization (Municipality)
model Organization {
  id                  String               @id @default(uuid())
  name                String               @unique // e.g., "City of Newark"
  slug                String               @unique // e.g., "newark"
  createdAt           DateTime             @default(now())
  
  // Relations
  profiles            Profile[]
  customRoles         CustomRole[]
  properties          Property[]
  businesses          Business[]
  projects            Project[]
  permits             Permit[]
  inspections         Inspection[]
  trackerItems        TrackerItem[]
  invites             Invite[]
  openRecordsRequests OpenRecordsRequest[]
}

// 2. Custom Role System (Isolated Per Org)
model CustomRole {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String        // e.g., "Water Dept Inspector", "Code Officer"
  createdAt      DateTime      @default(now())

  // Relations
  permissions    Permission[]
  profiles       Profile[]
  invites        Invite[]

  @@unique([organizationId, name]) // Names are unique within a single organization
}

// 3. Granular Module Permissions
model Permission {
  id             String        @id @default(uuid())
  roleId         String
  role           CustomRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module         String        // "command-center" | "tracker" | "gis" | "permits" | "code-enforcement" | "legislative" | "open-records"
  canView        Boolean       @default(false)
  canEdit        Boolean       @default(false)
  createdAt      DateTime      @default(now())

  @@unique([roleId, module])    // Unique permission card per module per role
}

// 4. User Profile (linked to Supabase auth.users.id)
model Profile {
  id             String        @id // Maps to Supabase auth.users.id
  email          String        @unique
  
  // Platform Permissions
  isGlobalAdmin  Boolean       @default(false)
  isOrgAdmin     Boolean       @default(false)
  
  // Organization Context
  organizationId String?       // Null for Global Admins
  organization   Organization? @relation(fields: [organizationId], references: [id])
  
  // Assigned Custom Role (required for Staff, null for Admins)
  roleId         String?       
  role           CustomRole?   @relation(fields: [roleId], references: [id])
  
  createdAt      DateTime      @default(now())
  sentInvites    Invite[]      @relation("InvitedBy")
}

// 5. Invitations Flow (Invite-Only)
model Invite {
  id             String        @id @default(uuid())
  email          String        @unique
  isOrgAdmin     Boolean       @default(false) // True if inviting the primary Org Admin
  roleId         String?       // Pre-assigned custom role for Staff
  role           CustomRole?   @relation(fields: [roleId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  token          String        @unique @default(dbgenerated("gen_random_uuid()"))
  status         String        @default("PENDING") // "PENDING" | "ACCEPTED" | "EXPIRED"
  expiresAt      DateTime
  invitedById    String
  invitedBy      Profile       @relation("InvitedBy", fields: [invitedById], references: [id])
  createdAt      DateTime      @default(now())
}

// Operational Tables
model Property {
  id             String         @id @default(uuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  address        String         @unique
  zipCode        String
  ownerName      String
  assessedValue  Float
  taxStatus      String         // "Paid" | "Delinquent"
  zoningDistrict String
  notes          String?
  permits        Permit[]
  inspections    Inspection[]
  trackerItems   TrackerItem[]
}

model Business {
  id               String         @id @default(uuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id])
  name             String         @unique
  sector           String
  complianceRating String         // "Grade A"
  projects         Project[]
}

model Project {
  id             String         @id @default(uuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  name           String         @unique
  status         String         // "Active" | "Completed"
  businessId     String
  business       Business       @relation(fields: [businessId], references: [id])
  permits        Permit[]
}

model Permit {
  id             String         @id @default(uuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  permitNumber   String         @unique
  type           String         // "Building" | "Zoning"
  status         String         // "Issued" | "Approved"
  estimatedCost  Float
  propertyId     String
  property       Property       @relation(fields: [propertyId], references: [id])
  projectId      String?
  project        Project?       @relation(fields: [projectId], references: [id])
  inspections    Inspection[]
}

model Inspection {
  id             String         @id @default(uuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  type           String         // "Structural" | "Safety"
  scheduledDate  DateTime
  status         String         // "Passed" | "Failed"
  inspectorName  String
  notes          String
  propertyId     String
  property       Property       @relation(fields: [propertyId], references: [id])
  permitId       String?
  permit         Permit?        @relation(fields: [permitId], references: [id])
}

model TrackerItem {
  id             String         @id @default(uuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  module         String         // "311" | "Permits"
  title          String
  status         String         // "Open" | "Resolved"
  priority       String         // "High" | "Medium"
  assignedTo     String
  slaDays        Int
  slaProgress    Int
  reportedDate   DateTime       @default(now())
  propertyId     String
  property       Property       @relation(fields: [propertyId], references: [id])
}

// 6. NEW MODEL: Open Records (FOIA-style Requests)
model OpenRecordsRequest {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  requesterName  String
  requesterEmail String
  description    String
  dateRange      String?
  status         String       @default("Received") // "Received" | "Under Review" | "Fulfilled" | "Denied"
  assignedTo     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}
